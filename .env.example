# ---- Jamf Pro (API Roles & Clients) ----
# Role needs read access to computers and smart computer groups.
JAMF_URL=https://your-instance.jamfcloud.com
JAMF_CLIENT_ID=your-jamf-api-client-id
JAMF_CLIENT_SECRET=your-jamf-api-client-secret

# ---- Okta (only needed if you use okta mappings) ----
# An SSWS API token from a service account with group-membership admin rights.
OKTA_ORG_URL=https://your-org.okta.com
OKTA_API_TOKEN=your-okta-ssws-token

# ---- Microsoft Entra (only needed if you use entra mappings) ----
# App registration with GroupMember.ReadWrite.All + User.Read.All (application).
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-app-client-id
ENTRA_CLIENT_SECRET=your-app-client-secret
